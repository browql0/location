# Backend
# Never commit real secrets. Use placeholders here and keep real values in local/host secrets only.
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/voiture_saas?schema=public
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_APP_URL=http://localhost:5173

# Cloudflare R2 (S3 compatible storage)
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_ACCOUNT_ID=replace-with-r2-account-id
R2_BUCKET_NAME=replace-with-r2-bucket-name
R2_ENDPOINT=https://replace-with-r2-account-id.r2.cloudflarestorage.com

# Email
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Seed
SUPER_ADMIN_EMAIL=admin@voiture-saas.local
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# Frontend
VITE_API_URL=http://localhost:4000/api/v1
